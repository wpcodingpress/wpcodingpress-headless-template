# WordPress Configuration
# These values will be automatically set during deployment
NEXT_PUBLIC_WORDPRESS_URL=https://your-wordpress-site.com
NEXT_PUBLIC_WORDPRESS_API_URL=https://your-wordpress-site.com/wp-json/headless/v1
WORDPRESS_API_KEY=your_api_key_here

# Site Data (automatically injected during deployment via WPCodingPress)
NEXT_PUBLIC_SITE_DATA={"settings":{"name":"My Site"}}
NEXT_PUBLIC_SITE_DATA_URL=https://your-wpcodingpress-app.com/api/sites/my-site/data
NEXT_PUBLIC_SITE_NAME=My Site

# Intelligence Data (automatically injected during deployment)
NEXT_PUBLIC_SITE_CATEGORY=business
NEXT_PUBLIC_SITE_CONFIDENCE=85
NEXT_PUBLIC_HAS_AUTH=false
NEXT_PUBLIC_HAS_FORMS=false
NEXT_PUBLIC_HAS_WOOCOMMERCE=false
NEXT_PUBLIC_HAS_SEARCH=false
NEXT_PUBLIC_HAS_COMMENTS=false
NEXT_PUBLIC_HAS_PORTFOLIO=false
NEXT_PUBLIC_HAS_SERVICES=true
NEXT_PUBLIC_HAS_TESTIMONIALS=false
NEXT_PUBLIC_HAS_TEAM=false
NEXT_PUBLIC_HAS_FAQ=false
NEXT_PUBLIC_PRIMARY_COLOR=#0284c7
NEXT_PUBLIC_SECTION_COUNT=8
NEXT_PUBLIC_HERO_LAYOUT=centered
